# ──────────────────────────────────────────────
# AI Appliance Inspection Platform — .gitignore
# Production-grade for AI/ML projects
# ──────────────────────────────────────────────

# ─── Python Bytecode & Cache ──────────────────
__pycache__/
*.py[cod]
*.pyo
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# ─── Virtual Environment ──────────────────────
.venv/
venv/
env/
envs/
.venv.bak/
venv.bak/
ENV/

# ─── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store
Thumbs.db
Desktop.ini
*.sublime-project
*.sublime-workspace

# ─── Project Data ─────────────────────────────
datasets/
data/
!data/.gitkeep
*.db
*.sqlite
*.sqlite3

# ─── Logs ─────────────────────────────────────
logs/
*.log

# ─── Output / Generated ───────────────────────
output/
reports/
temp/
tmp/
runs/
wandb/

# ─── Jupyter / Notebooks ──────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Testing ──────────────────────────────────
.pytest_cache/
.coverage
coverage/
htmlcov/
.coverage.*
*.coverage
.cache/
pytestdebug.log

# ─── Environment / Secrets ────────────────────
.env
.env.*
*.pem
*.key
*.cert
*.keystore
*.secret
credentials.json
client_secret*.json

# ─── Docker ───────────────────────────────────
.docker/

# ─── ML Training Artifacts ────────────────────
models/**/damage_*/
models/**/weights/
models/**/train/
models/**/val/
models/**/test/
wandb/
mlruns/

# ─── Large model files (>50MB tracked, <50MB OK) ─
# Keep all .pt files that are <50MB
# Exclude any checkpoint directories
**/checkpoints/
**/checkpoint-*/

# ─── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Misc ─────────────────────────────────────
# Keep .gitkeep files
!.gitkeep
*.bak
*.swp
*.swo
*~
*.orig
.DS_Store
